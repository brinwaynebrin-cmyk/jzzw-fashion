lt":"PRE-ORDER"}]}],"presets":[{"name":"JZZW V2 Black Gold","blocks":[{"type":"product","settings":{"product_name":"Obsidian Bomber","product_price":"$320","product_detail":"Japanese Nylon","badge":"PRE-ORDER"}},{"type":"product","settings":{"product_name":"Gold Seam Hoodie","product_price":"$185","product_detail":"400gsm Cotton","badge":""}},{"type":"product","settings":{"product_name":"Archive Trench","product_price":"$450","product_detail":"Italian Wool","badge":""}},{"type":"product","settings":{"product_name":"Signature Tee","product_price":"$95","product_detail":"Supima Cotton","badge":"NEW"}}]}]}{% endschema %}
