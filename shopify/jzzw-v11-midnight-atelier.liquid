{% comment %} JZZW V11 Midnight Atelier — Shopify Section {% endcomment %}
{%- comment -%} V11: Deep charcoal + champagne gold + ivory. Ultra-premium editorial. {%- endcomment -%}
<style>
.jzzw-v11{--bg:#1c1c1c;--fg:#f0ebe3;--gold:#c9a96e;--gold-dim:rgba(201,169,110,.3);--gray:#888;--serif:'Cormorant Garamond',Georgia,serif;--sans:'DM Sans',sans-serif}
.jzzw-v11 *{margin:0;padding:0;box-sizing:border-box}
.jzzw-v11{font-family:var(--sans);background:var(--bg);color:var(--fg);min-height:100vh;overflow-x:hidden;line-height:1.6}
.jzzw-v11 ::selection{background:var(--gold);color:var(--bg)}
.jzzw-v11 .nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.8rem 5rem;border-bottom:1px solid rgba(201,169,110,.12);background:rgba(28,28,28,.92);backdrop-filter:blur(24px)}
.jzzw-v11 .nav-brand{font-family:var(--serif);font-size:1.3rem;font-weight:500;letter-spacing:.35em;text-decoration:none;color:var(--fg);font-style:italic}
.jzzw-v11 .nav-links{display:flex;gap:2.5rem}
.jzzw-v11 .nav-links a{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;color:var(--fg);opacity:.35;transition:all .3s}
.jzzw-v11 .nav-links a:hover{opacity:1;color:var(--gold)}
.jzzw-v11 .nav-cta a{font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;color:var(--gold);border:1px solid var(--gold-dim);padding:.6rem 1.5rem;transition:all .3s}
.jzzw-v11 .nav-cta a:hover{background:var(--gold);color:var(--bg);border-color:var(--gold)}
.jzzw-v11 .hero{min-height:100vh;display:grid;grid-template-columns:50% 50%}
.jzzw-v11 .hero-left{padding:8rem 4rem 5rem 6rem;display:flex;flex-direction:column;justify-content:center;position:relative}
.jzzw-v11 .hero-left::before{content:'';position:absolute;top:0;left:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,var(--gold-dim),transparent)}
.jzzw-v11 .hero-season{font-size:.6rem;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:2.5rem;display:flex;align-items:center;gap:1rem}
.jzzw-v11 .hero-season::before{content:'';display:inline-block;width:24px;height:1px;background:var(--gold)}
.jzzw-v11 .hero-title{font-family:var(--serif);font-size:clamp(3rem,7vw,6rem);font-weight:400;line-height:1.08;letter-spacing:-.01em;margin-bottom:2rem}
.jzzw-v11 .hero-title em{font-style:italic;color:var(--gold)}
.jzzw-v11 .hero-title .outline{font-style:normal;-webkit-text-stroke:1px var(--fg);color:transparent}
.jzzw-v11 .hero-body{font-family:var(--sans);font-size:.92rem;font-weight:300;line-height:1.95;color:rgba(240,235,227,.48);max-width:380px;margin-bottom:3rem}
.jzzw-v11 .hero-actions{display:flex;gap:1.5rem;align-items:center}
.jzzw-v11 .btn-atelier-primary{padding:1rem 2.8rem;background:var(--gold);color:var(--bg);text-decoration:none;font-size:.7rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;transition:all .35s}
.jzzw-v11 .btn-atelier-primary:hover{background:#d4b87a;transform:translateY(-1px)}
.jzzw-v11 .btn-atelier-ghost{padding:1rem 2rem;background:transparent;color:var(--fg);text-decoration:none;font-size:.7rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;border:1px solid rgba(240,235,227,.12);transition:all .35s}
.jzzw-v11 .btn-atelier-ghost:hover{border-color:var(--gold);color:var(--gold)}
.jzzw-v11 .hero-right{background:linear-gradient(150deg,#1c1c1c 0%,#282420 40%,#1a1510 100%);position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.jzzw-v11 .hero-right::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,rgba(201,169,110,.12) 0%,transparent 55%)}
.jzzw-v11 .hero-emblem{position:relative;z-index:1;text-align:center}
.jzzw-v11 .hero-emblem-ring{width:260px;height:260px;border:1px solid rgba(201,169,110,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;position:relative}
.jzzw-v11 .hero-emblem-ring::before{content:'';position:absolute;width:220px;height:220px;border:1px solid rgba(201,169,110,.12);border-radius:50%}
.jzzw-v11 .hero-emblem-ring::after{content:'';position:absolute;width:180px;height:180px;border:1px solid rgba(201,169,110,.06);border-radius:50%}
.jzzw-v11 .hero-emblem-inner{font-family:var(--serif);font-style:italic;font-size:.7rem;letter-spacing:.4em;color:var(--gold);line-height:2.2;text-align:center}
.jzzw-v11 .strip{background:var(--gold);padding:1.2rem 0;overflow:hidden}
.jzzw-v11 .strip-inner{display:inline-flex;animation:marquee 18s linear infinite;white-space:nowrap}
.jzzw-v11 .strip-item{font-size:.7rem;letter-spacing:.3em;font-weight:600;color:var(--bg);padding:0 2.5rem}
.jzzw-v11 .strip-item::after{content:'✦';margin-left:2.5rem;opacity:.4}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.jzzw-v11 .editorial{padding:10rem 5rem;display:grid;grid-template-columns:35% 65%;gap:6rem;align-items:center;max-width:1400px;margin:0 auto}
.jzzw-v11 .editorial-label{font-size:.6rem;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:2rem}
.jzzw-v11 .editorial-heading{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.2;margin-bottom:2rem}
.jzzw-v11 .editorial-heading em{font-style:italic}
.jzzw-v11 .editorial-body{font-size:.88rem;font-weight:300;line-height:2;color:rgba(240,235,227,.5)}
.jzzw-v11 .products{padding:8rem 5rem;background:rgba(201,169,110,.025)}
.jzzw-v11 .products-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:5rem;padding-bottom:2rem;border-bottom:1px solid rgba(201,169,110,.1)}
.jzzw-v11 .products-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
.jzzw-v11 .products-title{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400}
.jzzw-v11 .products-count{font-size:.75rem;color:rgba(240,235,227,.25)}
.jzzw-v11 .products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.jzzw-v11 .product-card{background:rgba(255,255,255,.025);border:1px solid rgba(201,169,110,.07);transition:all .5s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden}
.jzzw-v11 .product-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform .5s;transform-origin:left}
.jzzw-v11 .product-card:hover{background:rgba(201,169,110,.04);border-color:rgba(201,169,110,.2);transform:translateY(-5px)}
.jzzw-v11 .product-card:hover::before{transform:scaleX(1)}
.jzzw-v11 .product-img{aspect-ratio:3/4;background:linear-gradient(145deg,#252525 0%,#1e1e1e 100%);position:relative;overflow:hidden}
.jzzw-v11 .product-img::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(201,169,110,.08) 0%,transparent 60%)}
.jzzw-v11 .product-num{position:absolute;top:1.2rem;left:1.2rem;font-size:.58rem;color:rgba(240,235,227,.2);letter-spacing:.1em}
.jzzw-v11 .product-badge{position:absolute;top:1.2rem;right:1.2rem;background:var(--gold);color:var(--bg);font-size:.52rem;font-weight:700;letter-spacing:.1em;padding:.3rem .7rem}
.jzzw-v11 .product-info{padding:1.8rem}
.jzzw-v11 .product-name{font-family:var(--serif);font-size:1.15rem;font-weight:400;margin-bottom:.4rem}
.jzzw-v11 .product-detail{font-size:.75rem;color:rgba(240,235,227,.35);margin-bottom:.8rem;letter-spacing:.02em}
.jzzw-v11 .product-price{font-size:1.05rem;font-weight:500;color:var(--gold)}
.jzzw-v11 .quote-section{padding:8rem 5rem;background:var(--bg);text-align:center;border-top:1px solid rgba(201,169,110,.08);border-bottom:1px solid rgba(201,169,110,.08)}
.jzzw-v11 .quote-label{font-size:.58rem;letter-spacing:.6em;text-transform:uppercase;color:var(--gold);margin-bottom:3rem}
.jzzw-v11 .quote-text{font-family:var(--serif);font-size:clamp(1.5rem,3.5vw,2.8rem);font-weight:400;font-style:italic;line-height:1.7;max-width:750px;margin:0 auto;color:rgba(240,235,227,.75)}
.jzzw-v11 .quote-text .gold{color:var(--gold);font-style:normal}
.jzzw-v11 .footer{background:#141414;padding:4rem 5rem;border-top:1px solid rgba(201,169,110,.08)}
.jzzw-v11 .footer-inner{max-width:1400px;margin:0 auto;display:flex;justify-content:space-between;align-items:center}
.jzzw-v11 .footer-brand{font-family:var(--serif);font-size:1.3rem;font-style:italic;letter-spacing:.2em;color:var(--gold)}
.jzzw-v11 .footer-links{display:flex;gap:3rem}
.jzzw-v11 .footer-links a{font-size:.72rem;color:rgba(240,235,227,.3);text-decoration:none;letter-spacing:.05em;transition:color .3s}
.jzzw-v11 .footer-links a:hover{color:var(--gold)}
.jzzw-v11 .footer-copy{font-size:.7rem;color:rgba(240,235,227,.18)}
@media(max-width:1024px){.jzzw-v11 .editorial{grid-template-columns:1fr;gap:3rem;padding:6rem 3rem}.jzzw-v11 .products-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.jzzw-v11 .hero{grid-template-columns:1fr}.jzzw-v11 .hero-right{min-height:50vh}.jzzw-v11 .nav{padding:1.2rem 2rem}.jzzw-v11 .products{padding:5rem 2rem}.jzzw-v11 .footer{flex-direction:column;gap:2rem;padding:3rem 2rem}.jzzw-v11 .footer-links{flex-wrap:wrap;gap:1.5rem}}
@media(max-width:480px){.jzzw-v11 .products-grid{grid-template-columns:1fr}}
</style>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<div class="jzzw-v11">
<nav class="nav">
<a href="/" class="nav-brand">{{ section.settings.brand | default: 'JZZW' }}</a>
<div class="nav-links">
<a href="#collection">{{ section.settings.nav1 | default: 'Collection' }}</a>
<a href="#editorial">{{ section.settings.nav2 | default: 'Atelier' }}</a>
<a href="#footer">{{ section.settings.nav3 | default: 'Contact' }}</a>
</div>
<div class="nav-cta"><a href="#collection">{{ section.settings.cta_nav | default: 'Shop Now' }}</a></div>
</nav>
<section class="hero">
<div class="hero-left">
<p class="hero-season">{{ section.settings.season | default: 'Spring / Summer 2026 — Atelier Collection' }}</p>
<h1 class="hero-title">{{ section.settings.title | default: 'The Art of<br><em>Quiet</em><br><span class="outline">Luxury</span>' }}</h1>
<p class="hero-body">{{ section.settings.body | default: 'Where silence speaks louder than noise. Each piece in the Atelier collection is a meditation on material, proportion, and the obsessive pursuit of the exceptional.' }}</p>
<div class="hero-actions">
<a href="#collection" class="btn-atelier-primary">{{ section.settings.cta | default: 'Explore Collection' }}</a>
<a href="#editorial" class="btn-atelier-ghost">{{ section.settings.cta2 | default: 'Read Story' }}</a>
</div>
</div>
<div class="hero-right">
<div class="hero-emblem">
<div class="hero-emblem-ring"><div class="hero-emblem-inner">{{ section.settings.emblem | default: 'JZZW<br><br>EST. 2024<br><br>ATELIER' }}</div></div>
</div>
</div>
</section>
<div class="strip">
<div class="strip-inner">
<span class="strip-item">{{ section.settings.s1 | default: 'ATELIER COLLECTION' }}</span>
<span class="strip-item">{{ section.settings.s2 | default: 'JAPANESE FABRIC' }}</span>
<span class="strip-item">{{ section.settings.s3 | default: 'HANDCRAFTED IN NYC' }}</span>
<span class="strip-item">{{ section.settings.s4 | default: 'LIMITED EDITION' }}</span>
<span class="strip-item">{{ section.settings.s1 | default: 'ATELIER COLLECTION' }}</span>
<span class="strip-item">{{ section.settings.s2 | default: 'JAPANESE FABRIC' }}</span>
<span class="strip-item">{{ section.settings.s3 | default: 'HANDCRAFTED IN NYC' }}</span>
<span class="strip-item">{{ section.settings.s4 | default: 'LIMITED EDITION' }}</span>
</div>
</div>
<section class="editorial" id="editorial">
<div>
<p class="editorial-label">{{ section.settings.ed_label | default: 'The Atelier' }}</p>
<h2 class="editorial-heading">{{ section.settings.ed_title | default: 'Made with <em>obsession</em>.' }}</h2>
</div>
<div>
<p class="editorial-body">{{ section.settings.ed_body | default: 'Every thread chosen by hand. Every seam finished with intention. The Atelier collection represents the highest expression of what JZZW stands for — not fashion, but craft. Not clothing, but conviction. We spend three times longer on each piece than industry standard, because quality is the only shortcut to timelessness.' }}</p>
</div>
</section>
<section class="products" id="collection">
<div class="products-header">
<div>
<p class="products-label">{{ section.settings.col_label | default: 'The Collection' }}</p>
<h2 class="products-title">{{ section.settings.col_title | default: 'Atelier SS 2026' }}</h2>
</div>
<p class="products-count">{{ section.settings.col_count | default: '06 Pieces' }}</p>
</div>
<div class="products-grid">
{% for block in section.blocks %}
<div class="product-card" {{ block.shopify_attributes }}>
<div class="product-img">
<span class="product-num">{{ forloop.index | string | pad_left: 2, '0' }}</span>
{% if block.settings.badge %}<span class="product-badge">{{ block.settings.badge }}</span>{% endif %}
</div>
<div class="product-info">
<h3 class="product-name">{{ block.settings.name | default: 'Product' }}</h3>
<p class="product-detail">{{ block.settings.detail | default: 'Premium Fabric' }}</p>
<p class="product-price">{{ block.settings.price | default: '$185' }}</p>
</div>
</div>
{% endfor %}
</div>
</section>
<section class="quote-section">
<p class="quote-label">{{ section.settings.q_label | default: 'Philosophy' }}</p>
<p class="quote-text">{{ section.settings.quote | default: 'Quality is the only <span class="gold">shortcut</span> to timelessness.' }}</p>
</section>
<footer class="footer" id="footer">
<div class="footer-inner">
<div class="footer-brand">{{ section.settings.brand | default: 'JZZW' }}</div>
<div class="footer-links">
<a href="#">All Products</a>
<a href="#">About</a>
<a href="#">Stockists</a>
<a href="#">Instagram</a>
</div>
<p class="footer-copy">© {{ 'now' | date: '%Y' }} — {{ section.settings.footer_loc | default: 'New York' }}</p>
</div>
</footer>
</div>
{% schema %}
{
  "name": "JZZW V11 Midnight Atelier",
  "tag": "section",
  "class": "jzzw-section",
  "settings": [
    {"type": "text", "id": "brand", "label": "Brand Name", "default": "JZZW"},
    {"type": "text", "id": "season", "label": "Season Label", "default": "Spring / Summer 2026 — Atelier Collection"},
    {"type": "textarea", "id": "title", "label": "Hero Title", "default": "The Art of<br><em>Quiet</em><br><span class=\"outline\">Luxury</span>"},
    {"type": "textarea", "id": "body", "label": "Hero Body Text", "default": "Where silence speaks louder than noise."},
    {"type": "text", "id": "cta", "label": "Primary CTA", "default": "Explore Collection"},
    {"type": "text", "id": "cta2", "label": "Secondary CTA", "default": "Read Story"},
    {"type": "text", "id": "cta_nav", "label": "Nav CTA", "default": "Shop Now"},
    {"type": "textarea", "id": "emblem", "label": "Hero Emblem Text", "default": "JZZW<br><br>EST. 2024<br><br>ATELIER"},
    {"type": "text", "id": "s1", "label": "Strip Item 1", "default": "ATELIER COLLECTION"},
    {"type": "text", "id": "s2", "label": "Strip Item 2", "default": "JAPANESE FABRIC"},
    {"type": "text", "id": "s3", "label": "Strip Item 3", "default": "HANDCRAFTED IN NYC"},
    {"type": "text", "id": "s4", "label": "Strip Item 4", "default": "LIMITED EDITION"},
    {"type": "text", "id": "nav1", "label": "Nav Link 1", "default": "Collection"},
    {"type": "text", "id": "nav2", "label": "Nav Link 2", "default": "Atelier"},
    {"type": "text", "id": "nav3", "label": "Nav Link 3", "default": "Contact"},
    {"type": "text", "id": "ed_label", "label": "Editorial Label", "default": "The Atelier"},
    {"type": "textarea", "id": "ed_title", "label": "Editorial Heading", "default": "Made with <em>obsession</em>."},
    {"type": "textarea", "id": "ed_body", "label": "Editorial Body", "default": "Every thread chosen by hand. Every seam finished with intention."},
    {"type": "text", "id": "col_label", "label": "Collection Label", "default": "The Collection"},
    {"type": "text", "id": "col_title", "label": "Collection Title", "default": "Atelier SS 2026"},
    {"type": "text", "id": "col_count", "label": "Collection Count", "default": "06 Pieces"},
    {"type": "text", "id": "q_label", "label": "Quote Label", "default": "Philosophy"},
    {"type": "textarea", "id": "quote", "label": "Quote Text", "default": "Quality is the only <span class=\"gold\">shortcut</span> to timelessness."},
    {"type": "text", "id": "footer_loc", "label": "Footer Location", "default": "New York"}
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Card",
      "limit": 6,
      "settings": [
        {"type": "text", "id": "name", "label": "Product Name", "default": "Atelier Bomber"},
        {"type": "text", "id": "price", "label": "Price", "default": "$385"},
        {"type": "text", "id": "detail", "label": "Detail / Material", "default": "Japanese Wool, Hand-finished"},
        {"type": "text", "id": "badge", "label": "Badge (optional)", "default": "Pre-Order"}
      ]
    }
  ],
  "presets": [
    {
      "name": "JZZW V11 Midnight Atelier",
      "blocks": [
        {"type": "product", "settings": {"name": "Atelier Bomber", "price": "$385", "detail": "Japanese Wool", "badge": "Pre-Order"}},
        {"type": "product", "settings": {"name": "Gold Seam Hoodie", "price": "$185", "detail": "400gsm Cotton", "badge": ""}},
        {"type": "product", "settings": {"name": "Archive Trench", "price": "$520", "detail": "Italian Wool Blend", "badge": ""}},
        {"type": "product", "settings": {"name": "Signature Tee", "price": "$110", "detail": "Supima Cotton", "badge": "New"}},
        {"type": "product", "settings": {"name": "Shadow Cargo", "price": "$265", "detail": "Cotton Twill", "badge": ""}},
        {"type": "product", "settings": {"name": "Midnight Denim", "price": "$310", "detail": "Selvedge Denim", "badge": ""}}
      ]
    }
  ]
}
{% endschema %}
