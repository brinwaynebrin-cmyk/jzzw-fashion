{% comment %} JZZW V12 Tokyo NYC — Shopify Section {% endcomment %}
{%- comment -%} V12: Wabi-sabi meets NYC. Warm paper white + indigo + terracotta. {%- endcomment -%}
<style>
.jzzw-v12{--bg:#f5f1ec;--fg:#2d2926;--indigo:#2c3e6b;--terra:#b85c38;--warm:#e8dfd4;--serif:'Playfair Display',Georgia,serif;--sans:'Inter',sans-serif}
.jzzw-v12 *{margin:0;padding:0;box-sizing:border-box}
.jzzw-v12{font-family:var(--sans);background:var(--bg);color:var(--fg);min-height:100vh;overflow-x:hidden;line-height:1.6}
.jzzw-v12 ::selection{background:var(--indigo);color:#fff}
.jzzw-v12 .nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.5rem 4rem;background:rgba(245,241,236,.93);backdrop-filter:blur(16px);border-bottom:1px solid rgba(45,41,38,.06)}
.jzzw-v12 .nav-brand{font-family:var(--serif);font-size:1.1rem;font-weight:500;font-style:italic;letter-spacing:.02em;text-decoration:none;color:var(--fg)}
.jzzw-v12 .nav-links{display:flex;gap:2.5rem}
.jzzw-v12 .nav-links a{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;color:var(--fg);opacity:.38;transition:all .3s}
.jzzw-v12 .nav-links a:hover{opacity:1;color:var(--indigo)}
.jzzw-v12 .hero{min-height:100vh;display:grid;grid-template-columns:45% 55%}
.jzzw-v12 .hero-left{background:linear-gradient(150deg,#f5f1ec 0%,#ede6dc 100%);display:flex;flex-direction:column;justify-content:center;padding:7rem 4rem 5rem 5rem;position:relative;overflow:hidden}
.jzzw-v12 .hero-left::before{content:'';position:absolute;top:0;right:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,rgba(44,62,107,.2),transparent)}
.jzzw-v12 .hero-tag{font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;color:var(--indigo);margin-bottom:2.5rem;display:flex;align-items:center;gap:.8rem}
.jzzw-v12 .hero-tag::before{content:'';display:inline-block;width:20px;height:1px;background:var(--indigo)}
.jzzw-v12 .hero-title{font-family:var(--serif);font-size:clamp(3rem,7vw,5.5rem);font-weight:400;line-height:1.08;letter-spacing:-.01em;margin-bottom:1.5rem}
.jzzw-v12 .hero-title em{font-style:italic;color:var(--terra)}
.jzzw-v12 .hero-sub{font-size:.9rem;font-weight:300;line-height:1.95;color:rgba(45,41,38,.5);max-width:360px;margin-bottom:2.5rem}
.jzzw-v12 .hero-actions{display:flex;gap:1rem;align-items:center}
.jzzw-v12 .btn-tokyo{padding:1rem 2.5rem;background:var(--indigo);color:#fff;text-decoration:none;font-size:.7rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;transition:all .3s}
.jzzw-v12 .btn-tokyo:hover{background:#3a5090;transform:translateY(-1px)}
.jzzw-v12 .btn-tokyo-ghost{padding:1rem 2rem;background:transparent;color:var(--fg);text-decoration:none;font-size:.7rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(45,41,38,.12);transition:all .3s}
.jzzw-v12 .btn-tokyo-ghost:hover{border-color:var(--terra);color:var(--terra)}
.jzzw-v12 .hero-right{background:linear-gradient(150deg,#2c3e6b 0%,#1e2d52 50%,#2c3e6b 100%);position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.jzzw-v12 .hero-right::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(184,92,56,.15) 0%,transparent 60%)}
.jzzw-v12 .hero-geo{position:relative;z-index:1;text-align:center}
.jzzw-v12 .hero-geo-circle{width:240px;height:240px;border:1px solid rgba(245,241,236,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;position:relative}
.jzzw-v12 .hero-geo-circle::before{content:'';position:absolute;width:200px;height:200px;border:1px solid rgba(245,241,236,.1);border-radius:50%}
.jzzw-v12 .hero-geo-inner{font-family:var(--serif);font-style:italic;font-size:.65rem;letter-spacing:.35em;color:rgba(245,241,236,.6);line-height:2;text-align:center}
.jzzw-v12 .hero-geo-label{position:absolute;top:50%;left:calc(50% + 130px);transform:translateY(-50%);font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(245,241,236,.3);writing-mode:vertical-rl}
.jzzw-v12 .strip{background:var(--terra);padding:1.2rem 0;overflow:hidden}
.jzzw-v12 .strip-inner{display:inline-flex;animation:marquee 16s linear infinite}
.jzzw-v12 .strip-item{font-size:.72rem;letter-spacing:.3em;font-weight:600;color:#fff;padding:0 2.5rem}
.jzzw-v12 .strip-item::after{content:'—';margin-left:2.5rem;opacity:.4}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.jzzw-v12 .split{padding:8rem 0;display:grid;grid-template-columns:1fr 1fr;min-height:70vh}
.jzzw-v12 .split-left{background:var(--warm);padding:6rem 4rem;display:flex;flex-direction:column;justify-content:center;position:relative}
.jzzw-v12 .split-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--terra);margin-bottom:2rem}
.jzzw-v12 .split-heading{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.2;margin-bottom:1.5rem}
.jzzw-v12 .split-heading em{font-style:italic}
.jzzw-v12 .split-body{font-size:.88rem;font-weight:300;line-height:2;color:rgba(45,41,38,.5)}
.jzzw-v12 .split-right{background:var(--indigo);padding:6rem 4rem;display:flex;flex-direction:column;justify-content:center;position:relative}
.jzzw-v12 .split-right .split-label{color:rgba(245,241,236,.4)}
.jzzw-v12 .split-right .split-heading{color:#f5f1ec}
.jzzw-v12 .split-right .split-body{color:rgba(245,241,236,.5)}
.jzzw-v12 .products{padding:8rem 4rem;background:var(--bg)}
.jzzw-v12 .products-header{margin-bottom:5rem;padding-bottom:2rem;border-bottom:1px solid rgba(45,41,38,.08)}
.jzzw-v12 .products-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--terra);margin-bottom:1rem}
.jzzw-v12 .products-title{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400}
.jzzw-v12 .products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.jzzw-v12 .product-card{background:#fff;border:1px solid rgba(45,41,38,.06);transition:all .4s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden;box-shadow:0 2px 12px rgba(45,41,38,.04)}
.jzzw-v12 .product-card:hover{transform:translateY(-5px);box-shadow:0 12px 40px rgba(45,41,38,.1);border-color:rgba(184,92,56,.2)}
.jzzw-v12 .product-img{aspect-ratio:3/4;background:linear-gradient(145deg,#f0ebe3 0%,#e5ddd3 100%);position:relative}
.jzzw-v12 .product-img::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,rgba(184,92,56,.08) 0%,transparent 50%)}
.jzzw-v12 .product-num{position:absolute;top:1rem;left:1rem;font-size:.58rem;color:rgba(45,41,38,.18);letter-spacing:.1em}
.jzzw-v12 .product-badge{position:absolute;top:1rem;right:1rem;background:var(--terra);color:#fff;font-size:.52rem;font-weight:700;letter-spacing:.1em;padding:.3rem .7rem}
.jzzw-v12 .product-info{padding:1.5rem}
.jzzw-v12 .product-name{font-family:var(--serif);font-size:1.1rem;font-weight:400;margin-bottom:.3rem}
.jzzw-v12 .product-detail{font-size:.75rem;color:rgba(45,41,38,.4);margin-bottom:.7rem}
.jzzw-v12 .product-price{font-size:1.05rem;font-weight:600;color:var(--terra)}
.jzzw-v12 .quote{padding:8rem 5rem;background:var(--warm);text-align:center;border-top:1px solid rgba(45,41,38,.06)}
.jzzw-v12 .quote-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--indigo);margin-bottom:2.5rem}
.jzzw-v12 .quote-text{font-family:var(--serif);font-size:clamp(1.5rem,3vw,2.8rem);font-weight:400;font-style:italic;line-height:1.7;max-width:750px;margin:0 auto;color:rgba(45,41,38,.7)}
.jzzw-v12 .quote-text .terra{color:var(--terra);font-style:normal}
.jzzw-v12 .footer{background:var(--fg);padding:4rem 4rem}
.jzzw-v12 .footer-inner{max-width:1400px;margin:0 auto;display:flex;justify-content:space-between;align-items:center}
.jzzw-v12 .footer-brand{font-family:var(--serif);font-size:1.1rem;font-style:italic;color:var(--bg)}
.jzzw-v12 .footer-links{display:flex;gap:2.5rem}
.jzzw-v12 .footer-links a{font-size:.72rem;color:rgba(245,241,236,.3);text-decoration:none;transition:color .3s}
.jzzw-v12 .footer-links a:hover{color:var(--terra)}
.jzzw-v12 .footer-copy{font-size:.7rem;color:rgba(245,241,236,.18)}
@media(max-width:900px){.jzzw-v12 .hero{grid-template-columns:1fr}.jzzw-v12 .hero-right{min-height:50vh}.jzzw-v12 .split{grid-template-columns:1fr}.jzzw-v12 .products-grid{grid-template-columns:repeat(2,1fr)}.jzzw-v12 .nav{padding:1rem 2rem}}
@media(max-width:600px){.jzzw-v12 .products-grid{grid-template-columns:1fr}}
</style>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,300;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<div class="jzzw-v12">
<nav class="nav">
<a href="/" class="nav-brand">{{ section.settings.brand | default: 'JZZW' }}</a>
<div class="nav-links">
<a href="#collection">{{ section.settings.n1 | default: 'Collection' }}</a>
<a href="#split">{{ section.settings.n2 | default: 'Philosophy' }}</a>
<a href="#footer">{{ section.settings.n3 | default: 'Contact' }}</a>
</div>
</nav>
<section class="hero">
<div class="hero-left">
<p class="hero-tag">{{ section.settings.tag | default: 'Tokyo × New York — SS 2026' }}</p>
<h1 class="hero-title">{{ section.settings.title | default: 'Where East<br>Meets <em>Street</em>' }}</h1>
<p class="hero-sub">{{ section.settings.sub | default: 'Two cities, one standard. The Tokyo NYC collection merges Japanese wabi-sabi sensibility with the raw confidence of New York street culture.' }}</p>
<div class="hero-actions">
<a href="#collection" class="btn-tokyo">{{ section.settings.cta | default: 'Shop Collection' }}</a>
<a href="#split" class="btn-tokyo-ghost">{{ section.settings.cta2 | default: 'Our Story' }}</a>
</div>
</div>
<div class="hero-right">
<div class="hero-geo">
<div class="hero-geo-circle"><div class="hero-geo-inner">{{ section.settings.emblem | default: 'JZZW<br><br>TOKYO<br>×<br>NYC' }}</div></div>
<span class="hero-geo-label">{{ section.settings.geo_label | default: '35.6762° N 139.6503° E' }}</span>
</div>
</div>
</section>
<div class="strip">
<div class="strip-inner">
<span class="strip-item">{{ section.settings.s1 | default: 'TOKYO × NYC' }}</span>
<span class="strip-item">{{ section.settings.s2 | default: 'WABI-SABI SOUL' }}</span>
<span class="strip-item">{{ section.settings.s3 | default: 'HANDCRAFTED' }}</span>
<span class="strip-item">{{ section.settings.s4 | default: 'SS 2026' }}</span>
<span class="strip-item">{{ section.settings.s1 | default: 'TOKYO × NYC' }}</span>
<span class="strip-item">{{ section.settings.s2 | default: 'WABI-SABI SOUL' }}</span>
<span class="strip-item">{{ section.settings.s3 | default: 'HANDCRAFTED' }}</span>
<span class="strip-item">{{ section.settings.s4 | default: 'SS 2026' }}</span>
</div>
</div>
<section class="split" id="split">
<div class="split-left">
<p class="split-label">{{ section.settings.split1_label | default: 'Tokyo' }}</p>
<h2 class="split-heading">{{ section.settings.split1_title | default: 'The Art of <em>Enough</em>' }}</h2>
<p class="split-body">{{ section.settings.split1_body | default: 'Wabi-sabi teaches us that perfection is found in imperfection. The slight irregularity in the weave, the natural variation in the dye — these are not flaws, they are signatures of hands that cared.' }}</p>
</div>
<div class="split-right">
<p class="split-label">{{ section.settings.split2_label | default: 'New York' }}</p>
<h2 class="split-heading">{{ section.settings.split2_title | default: 'No <em>Apologies</em>' }}</h2>
<p class="split-body">{{ section.settings.split2_body | default: 'New York doesn''t do quiet. We design with the same energy — bold cuts, unapologetic proportions, and the kind of presence that turns a room before you speak.' }}</p>
</div>
</section>
<section class="products" id="collection">
<div class="products-header">
<p class="products-label">{{ section.settings.col_label | default: 'The Collection' }}</p>
<h2 class="products-title">{{ section.settings.col_title | default: 'Tokyo × NYC — SS 2026' }}</h2>
</div>
<div class="products-grid">
{% for block in section.blocks %}
<div class="product-card" {{ block.shopify_attributes }}>
<div class="product-img">
<span class="product-num">{{ forloop.index | string | pad_left: 2, '0' }}</span>
{% if block.settings.badge %}<span class="product-badge">{{ block.settings.badge }}</span>{% endif %}
</div>
<div class="product-info">
<h3 class="product-name">{{ block.settings.name | default: 'Product' }}</h3>
<p class="product-detail">{{ block.settings.detail | default: 'Premium Fabric' }}</p>
<p class="product-price">{{ block.settings.price | default: '$185' }}</p>
</div>
</div>
{% endfor %}
</div>
</section>
<section class="quote">
<p class="quote-label">{{ section.settings.q_label | default: 'Philosophy' }}</p>
<p class="quote-text">{{ section.settings.quote | default: 'Perfection is boring. <span class="terra">Imperfection</span> is interesting.' }}</p>
</section>
<footer class="footer" id="footer">
<div class="footer-inner">
<div class="footer-brand">{{ section.settings.brand | default: 'JZZW' }}</div>
<div class="footer-links">
<a href="#">All Products</a>
<a href="#">About</a>
<a href="#">Stockists</a>
<a href="#">Instagram</a>
</div>
<p class="footer-copy">© {{ 'now' | date: '%Y' }} — Tokyo × New York</p>
</div>
</footer>
</div>
{% schema %}
{
  "name": "JZZW V12 Tokyo NYC",
  "tag": "section",
  "class": "jzzw-section",
  "settings": [
    {"type": "text", "id": "brand", "label": "Brand Name", "default": "JZZW"},
    {"type": "text", "id": "tag", "label": "Hero Tag", "default": "Tokyo × New York — SS 2026"},
    {"type": "textarea", "id": "title", "label": "Hero Title", "default": "Where East<br>Meets <em>Street</em>"},
    {"type": "textarea", "id": "sub", "label": "Hero Subtitle", "default": "Two cities, one standard."},
    {"type": "text", "id": "cta", "label": "Primary CTA", "default": "Shop Collection"},
    {"type": "text", "id": "cta2", "label": "Secondary CTA", "default": "Our Story"},
    {"type": "textarea", "id": "emblem", "label": "Emblem Text", "default": "JZZW<br><br>TOKYO<br>×<br>NYC"},
    {"type": "text", "id": "geo_label", "label": "Geo Label", "default": "35.6762° N 139.6503° E"},
    {"type": "text", "id": "s1", "label": "Strip 1", "default": "TOKYO × NYC"},
    {"type": "text", "id": "s2", "label": "Strip 2", "default": "WABI-SABI SOUL"},
    {"type": "text", "id": "s3", "label": "Strip 3", "default": "HANDCRAFTED"},
    {"type": "text", "id": "s4", "label": "Strip 4", "default": "SS 2026"},
    {"type": "text", "id": "n1", "label": "Nav 1", "default": "Collection"},
    {"type": "text", "id": "n2", "label": "Nav 2", "default": "Philosophy"},
    {"type": "text", "id": "n3", "label": "Nav 3", "default": "Contact"},
    {"type": "text", "id": "split1_label", "label": "Split Left Label", "default": "Tokyo"},
    {"type": "text", "id": "split1_title", "label": "Split Left Title", "default": "The Art of <em>Enough</em>"},
    {"type": "textarea", "id": "split1_body", "label": "Split Left Body", "default": "Wabi-sabi teaches us that perfection is found in imperfection."},
    {"type": "text", "id": "split2_label", "label": "Split Right Label", "default": "New York"},
    {"type": "text", "id": "split2_title", "label": "Split Right Title", "default": "No <em>Apologies</em>"},
    {"type": "textarea", "id": "split2_body", "label": "Split Right Body", "default": "New York doesn't do quiet. We design with the same energy."},
    {"type": "text", "id": "col_label", "label": "Collection Label", "default": "The Collection"},
    {"type": "text", "id": "col_title", "label": "Collection Title", "default": "Tokyo × NYC — SS 2026"},
    {"type": "text", "id": "q_label", "label": "Quote Label", "default": "Philosophy"},
    {"type": "textarea", "id": "quote", "label": "Quote Text", "default": "Perfection is boring. <span class=\"terra\">Imperfection</span> is interesting."}
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Card",
      "limit": 6,
      "settings": [
        {"type": "text", "id": "name", "label": "Product Name", "default": "Wabi-Sabi Bomber"},
        {"type": "text", "id": "price", "label": "Price", "default": "$365"},
        {"type": "text", "id": "detail", "label": "Detail", "default": "Japanese Cotton, Indigo-dyed"},
        {"type": "text", "id": "badge", "label": "Badge", "default": "Pre-Order"}
      ]
    }
  ],
  "presets": [
    {
      "name": "JZZW V12 Tokyo NYC",
      "blocks": [
        {"type": "product", "settings": {"name": "Wabi-Sabi Bomber", "price": "$365", "detail": "Japanese Cotton, Indigo-dyed", "badge": "Pre-Order"}},
        {"type": "product", "settings": {"name": "Indigo Hoodie", "price": "$195", "detail": "400gsm Cotton", "badge": ""}},
        {"type": "product", "settings": {"name": "Terra Trench", "price": "$485", "detail": "Japanese Wool", "badge": ""}},
        {"type": "product", "settings": {"name": "Tokyo Tee", "price": "$95", "detail": "Supima Cotton", "badge": "New"}},
        {"type": "product", "settings": {"name": "Shiro Cargo", "price": "$275", "detail": "Cotton Twill", "badge": ""}},
        {"type": "product", "settings": {"name": "Midnight Selvedge", "price": "$320", "detail": "Selvedge Denim", "badge": ""}}
      ]
