    {"type": "text", "id": "cta", "label": "Primary CTA", "default": "Shop Collection"},
    {"type": "text", "id": "cta2", "label": "Secondary CTA", "default": "Read Story"},
    {"type": "textarea", "id": "caption", "label": "Hero Caption", "default": "Each piece archived. <em>Never discontinued.</em>"},
    {"type": "text", "id": "s1", "label": "Strip 1", "default": "Studio Archive"},
    {"type": "text", "id": "s2", "label": "Strip 2", "default": "Craft Over Trend"},
    {"type": "text", "id": "s3", "label": "Strip 3", "default": "SS 2026"},
    {"type": "text", "id": "s4", "label": "Strip 4", "default": "New York"},
    {"type": "text", "id": "n1", "label": "Nav 1", "default": "Collection"},
    {"type": "text", "id": "n2", "label": "Nav 2", "default": "Archive"},
    {"type": "text", "id": "n3", "label": "Nav 3", "default": "Contact"},
    {"type": "text", "id": "arc_num", "label": "Archive Number", "default": "001"},
    {"type": "text", "id": "arc_label", "label": "Archive Label", "default": "The Archive"},
    {"type": "textarea", "id": "arc_title", "label": "Archive Heading", "default": "Craft is the <em>only</em><br>currency"},
    {"type": "textarea", "id": "arc_body", "label": "Archive Body", "default": "Every piece carries a serial number. Not because we believe in exclusivity — but because we believe in accountability."},
    {"type": "text", "id": "arc_detail", "label": "Archive Detail", "default": "Each garment hand-finished in our New York atelier."},
    {"type": "text", "id": "col_label", "label": "Collection Label", "default": "The Archive"},
    {"type": "text", "id": "col_title", "label": "Collection Title", "default": "SS 2026 — Archive Collection"},
