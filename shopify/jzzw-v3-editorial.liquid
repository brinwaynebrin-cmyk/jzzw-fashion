ault":"Japanese Nylon, Hand-finished"}]}],"presets":[{"name":"JZZW V3 Editorial","blocks":[{"type":"product","settings":{"product_name":"Obsidian Bomber","product_price":"$320","product_detail":"Japanese Nylon"}},{"type":"product","settings":{"product_name":"Gold Seam Hoodie","product_price":"$185","product_detail":"400gsm Cotton"}},{"type":"product","settings":{"product_name":"Archive Trench","product_price":"$450","product_detail":"Italian Wool Blend"}},{"type":"product","settings":{"product_name":"Signature Tee","product_price":"$95","product_detail":"Supima Cotton"}},{"type":"product","settings":{"product_name":"Shadow Cargo","product_price":"$240","product_detail":"Japanese Cotton Twill"}},{"type":"product","settings":{"product_name":"Midnight Denim","product_price":"$280","product_detail":"Selvedge Denim"}}]}]}{% endschema %}
