    {"type": "text", "id": "v_detail", "label": "Vintage Detail Quote", "default": "\"American craftsmanship is not dead. We're just harder to find.\""},
    {"type": "text", "id": "col_label", "label": "Collection Label", "default": "The Collection"},
    {"type": "text", "id": "col_title", "label": "Collection Title", "default": "Retrograde SS 2026"},
