{% comment %} JZZW V14 Retrograde — Shopify Section (Vintage Sportswear / Americana Premium) {% endcomment %}
<style>
.jzzw-v14{--bg:#f4efe6;--fg:#1c1814;--navy:#1a2744;--rust:#b5451b;--cream:#e8e0d4;--serif:'Playfair Display',Georgia,serif;--sans:'Work Sans',sans-serif}
.jzzw-v14 *{margin:0;padding:0;box-sizing:border-box}
.jzzw-v14{font-family:var(--sans);background:var(--bg);color:var(--fg);min-height:100vh;overflow-x:hidden;line-height:1.6}
.jzzw-v14 ::selection{background:var(--navy);color:#fff}
.jzzw-v14 .nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.5rem 4rem;background:rgba(244,239,230,.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(28,24,20,.08)}
.jzzw-v14 .nav-brand{font-family:var(--serif);font-size:1.2rem;font-weight:700;letter-spacing:.05em;text-decoration:none;color:var(--fg);text-transform:uppercase;font-style:italic}
.jzzw-v14 .nav-links{display:flex;gap:2.5rem}
.jzzw-v14 .nav-links a{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;text-decoration:none;color:var(--fg);opacity:.35;transition:opacity .3s}
.jzzw-v14 .nav-links a:hover{opacity:1}
.jzzw-v14 .nav-cta a{font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;color:var(--navy);border:1px solid var(--navy);padding:.6rem 1.5rem;transition:all .3s}
.jzzw-v14 .nav-cta a:hover{background:var(--navy);color:#fff}
.jzzw-v14 .hero{min-height:100vh;display:grid;grid-template-columns:50% 50%}
.jzzw-v14 .hero-left{padding:7rem 4rem 5rem 5rem;display:flex;flex-direction:column;justify-content:center;position:relative;background:linear-gradient(135deg,#f4efe6 0%,#ece5d8 100%)}
.jzzw-v14 .hero-left::before{content:'';position:absolute;top:0;right:0;bottom:0;width:1px;background:rgba(28,24,20,.08)}
.jzzw-v14 .hero-tag{font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;color:var(--rust);margin-bottom:2rem;display:flex;align-items:center;gap:1rem}
.jzzw-v14 .hero-tag::before{content:'';display:inline-block;width:30px;height:1px;background:var(--rust)}
.jzzw-v14 .hero-title{font-family:var(--serif);font-size:clamp(3rem,7vw,5.5rem);font-weight:700;text-transform:uppercase;line-height:.9;letter-spacing:-.01em;margin-bottom:1.5rem}
.jzzw-v14 .hero-title em{font-style:italic;font-weight:400;color:var(--navy);display:block}
.jzzw-v14 .hero-sub{font-size:.9rem;font-weight:400;line-height:1.95;color:rgba(28,24,20,.45);max-width:360px;margin-bottom:2.5rem}
.jzzw-v14 .hero-actions{display:flex;gap:.8rem}
.jzzw-v14 .btn-retro{padding:1rem 2.5rem;background:var(--rust);color:#fff;text-decoration:none;font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;transition:all .3s}
.jzzw-v14 .btn-retro:hover{background:var(--navy);transform:translateY(-1px)}
.jzzw-v14 .btn-retro-ghost{padding:1rem 2rem;background:transparent;color:var(--fg);text-decoration:none;font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(28,24,20,.12);transition:all .3s}
.jzzw-v14 .btn-retro-ghost:hover{border-color:var(--rust);color:var(--rust)}
.jzzw-v14 .hero-right{background:var(--navy);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.jzzw-v14 .hero-right::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 40px,rgba(255,255,255,.015) 40px,rgba(255,255,255,.015) 41px)}
.jzzw-v14 .hero-right::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(181,69,27,.15) 0%,transparent 60%)}
.jzzw-v14 .hero-emblem{position:relative;z-index:1;text-align:center}
.jzzw-v14 .hero-emblem-star{width:200px;height:200px;border:2px solid rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 2rem;position:relative}
.jzzw-v14 .hero-emblem-star::before{content:'';position:absolute;width:170px;height:170px;border:1px solid rgba(255,255,255,.08);border-radius:50%}
.jzzw-v14 .hero-emblem-inner{font-family:var(--serif);font-size:2.5rem;font-weight:700;color:rgba(255,255,255,.7);letter-spacing:.05em}
.jzzw-v14 .hero-emblem-est{font-size:.65rem;letter-spacing:.5em;color:rgba(255,255,255,.25);text-transform:uppercase}
.jzzw-v14 .hero-emblem-sub{font-size:.7rem;letter-spacing:.2em;color:rgba(255,255,255,.35);margin-top:.5rem;text-transform:uppercase}
.jzzw-v14 .strip{background:var(--cream);padding:1.2rem 0;overflow:hidden;border-top:2px solid rgba(28,24,20,.06);border-bottom:2px solid rgba(28,24,20,.06)}
.jzzw-v14 .strip-inner{display:inline-flex;animation:marquee 18s linear infinite}
.jzzw-v14 .strip-item{font-family:var(--serif);font-size:.85rem;font-style:italic;color:var(--navy);padding:0 2.5rem;white-space:nowrap}
.jzzw-v14 .strip-item::after{content:'★';margin-left:2.5rem;opacity:.3}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.jzzw-v14 .vintage{padding:8rem 5rem;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;max-width:1300px;margin:0 auto}
.jzzw-v14 .vintage-img{aspect-ratio:4/5;background:linear-gradient(145deg,#ece5d8 0%,#e0d8cb 100%);position:relative;overflow:hidden;border:4px solid rgba(28,24,20,.04)}
.jzzw-v14 .vintage-img::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(28,24,20,.015) 3px,rgba(28,24,20,.015) 4px)}
.jzzw-v14 .vintage-img-label{position:absolute;bottom:1.5rem;left:1.5rem;font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(28,24,20,.25);z-index:1}
.jzzw-v14 .vintage-content{display:flex;flex-direction:column;justify-content:center}
.jzzw-v14 .vintage-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--rust);margin-bottom:2rem}
.jzzw-v14 .vintage-heading{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:700;text-transform:uppercase;line-height:.95;margin-bottom:1.5rem}
.jzzw-v14 .vintage-heading em{font-style:italic;font-weight:400;color:var(--navy);display:block}
.jzzw-v14 .vintage-body{font-size:.88rem;font-weight:400;line-height:2;color:rgba(28,24,20,.45);margin-bottom:2rem}
.jzzw-v14 .vintage-detail{font-family:var(--serif);font-size:.85rem;font-style:italic;color:var(--rust);border-left:2px solid var(--rust);padding-left:1.5rem}
.jzzw-v14 .products{padding:8rem 5rem;background:rgba(181,69,27,.03);border-top:1px solid rgba(28,24,20,.06)}
.jzzw-v14 .products-header{margin-bottom:4rem;padding-bottom:2rem;border-bottom:2px solid rgba(28,24,20,.06);display:flex;justify-content:space-between;align-items:flex-end}
.jzzw-v14 .products-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--rust);margin-bottom:.8rem}
.jzzw-v14 .products-title{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:700;text-transform:uppercase}
.jzzw-v14 .products-count{font-size:.7rem;color:rgba(28,24,20,.25);letter-spacing:.1em}
.jzzw-v14 .products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.jzzw-v14 .product-card{background:#fff;border:1px solid rgba(28,24,20,.06);transition:all .4s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden}
.jzzw-v14 .product-card:hover{transform:translateY(-5px);box-shadow:0 12px 40px rgba(28,24,20,.1);border-color:rgba(181,69,27,.2)}
.jzzw-v14 .product-img{aspect-ratio:3/4;background:linear-gradient(145deg,#ece5d8 0%,#e0d8cb 100%);position:relative;overflow:hidden}
.jzzw-v14 .product-img::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 20%,rgba(181,69,27,.08) 0%,transparent 50%)}
.jzzw-v14 .product-num{position:absolute;top:1rem;left:1rem;font-size:.58rem;color:rgba(28,24,20,.15);letter-spacing:.1em}
.jzzw-v14 .product-badge{position:absolute;top:1rem;right:1rem;background:var(--rust);color:#fff;font-size:.5rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;padding:.25rem .6rem}
.jzzw-v14 .product-info{padding:1.5rem;border-top:1px solid rgba(28,24,20,.04)}
.jzzw-v14 .product-name{font-family:var(--serif);font-size:1rem;font-weight:700;text-transform:uppercase;margin-bottom:.3rem}
.jzzw-v14 .product-detail{font-size:.72rem;color:rgba(28,24,20,.35);margin-bottom:.7rem}
.jzzw-v14 .product-price{font-size:1rem;font-weight:700;color:var(--navy)}
.jzzw-v14 .quote-section{padding:8rem 5rem;background:var(--navy);text-align:center;border-top:1px solid rgba(28,24,20,.1)}
.jzzw-v14 .quote-label{font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:2.5rem}
.jzzw-v14 .quote-text{font-family:var(--serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:700;text-transform:uppercase;line-height:1.1;letter-spacing:-.01em;color:rgba(255,255,255,.75)}
.jzzw-v14 .quote-text .rust{color:var(--rust);font-style:italic;font-weight:400;text-transform:none}
.jzzw-v14 .footer{background:var(--fg);padding:4rem 5rem;border-top:2px solid rgba(28,24,20,.06)}
.jzzw-v14 .footer-inner{max-width:1300px;margin:0 auto;display:flex;justify-content:space-between;align-items:center}
.jzzw-v14 .footer-brand{font-family:var(--serif);font-size:1.2rem;font-weight:700;text-transform:uppercase;font-style:italic;color:var(--cream)}
.jzzw-v14 .footer-links{display:flex;gap:2.5rem}
.jzzw-v14 .footer-links a{font-size:.7rem;color:rgba(244,239,230,.2);text-decoration:none;letter-spacing:.05em;transition:color .3s}
.jzzw-v14 .footer-links a:hover{color:var(--rust)}
.jzzw-v14 .footer-copy{font-size:.68rem;color:rgba(244,239,230,.12)}
@media(max-width:1024px){.jzzw-v14 .vintage{grid-template-columns:1fr;gap:3rem;padding:6rem 3rem}.jzzw-v14 .products-grid{grid-template-columns:repeat(2,1fr)}.jzzw-v14 .nav{padding:1.2rem 2rem}}
@media(max-width:768px){.jzzw-v14 .hero{grid-template-columns:1fr}.jzzw-v14 .hero-right{min-height:50vh}.jzzw-v14 .products{padding:5rem 2rem}.jzzw-v14 .footer{flex-direction:column;gap:2rem;padding:3rem 2rem}.jzzw-v14 .footer-links{flex-wrap:wrap;gap:1.5rem}}
@media(max-width:480px){.jzzw-v14 .products-grid{grid-template-columns:1fr}}
</style>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,300;1,400;1,700&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<div class="jzzw-v14">
<nav class="nav">
<a href="/" class="nav-brand">{{ section.settings.brand | default: 'JZZW' }}</a>
<div class="nav-links">
<a href="#collection">{{ section.settings.n1 | default: 'Collection' }}</a>
<a href="#vintage">{{ section.settings.n2 | default: 'Story' }}</a>
<a href="#footer">{{ section.settings.n3 | default: 'Contact' }}</a>
</div>
<div class="nav-cta"><a href="#collection">{{ section.settings.cta_nav | default: 'Shop Now' }}</a></div>
</nav>
<section class="hero">
<div class="hero-left">
<p class="hero-tag">{{ section.settings.tag | default: 'Retrograde — SS 2026' }}</p>
<h1 class="hero-title">{{ section.settings.title | default: 'AMERI<br><em>cana</em>' }}</h1>
<p class="hero-sub">{{ section.settings.sub | default: 'Heritage reborn. The Retrograde collection channels the spirit of American craftsmanship — the grit of the workyard, the pride of the maker, the soul of the open road.' }}</p>
<div class="hero-actions">
<a href="#collection" class="btn-retro">{{ section.settings.cta | default: 'Shop Collection' }}</a>
<a href="#vintage" class="btn-retro-ghost">{{ section.settings.cta2 | default: 'Our Story' }}</a>
</div>
</div>
<div class="hero-right">
<div class="hero-emblem">
<div class="hero-emblem-star"><div class="hero-emblem-inner">{{ section.settings.emblem | default: 'JZ' }}</div></div>
<p class="hero-emblem-est">{{ section.settings.est | default: 'EST. 2024' }}</p>
<p class="hero-emblem-sub">{{ section.settings.emblem_sub | default: 'New York' }}</p>
</div>
</div>
</section>
<div class="strip">
<div class="strip-inner">
<span class="strip-item">{{ section.settings.s1 | default: 'American Made' }}</span>
<span class="strip-item">{{ section.settings.s2 | default: 'Retrograde' }}</span>
<span class="strip-item">{{ section.settings.s3 | default: 'SS 2026' }}</span>
<span class="strip-item">{{ section.settings.s4 | default: 'Heritage Reborn' }}</span>
<span class="strip-item">{{ section.settings.s1 | default: 'American Made' }}</span>
<span class="strip-item">{{ section.settings.s2 | default: 'Retrograde' }}</span>
<span class="strip-item">{{ section.settings.s3 | default: 'SS 2026' }}</span>
<span class="strip-item">{{ section.settings.s4 | default: 'Heritage Reborn' }}</span>
</div>
</div>
<section class="vintage" id="vintage">
<div class="vintage-img">
<span class="vintage-img-label">{{ section.settings.img_label | default: 'Archive No. 001' }}</span>
</div>
<div class="vintage-content">
<p class="vintage-label">{{ section.settings.v_label | default: 'Heritage' }}</p>
<h2 class="vintage-heading">{{ section.settings.v_title | default: 'Made in<br><em>America</em>' }}</h2>
<p class="vintage-body">{{ section.settings.v_body | default: 'We source materials from mills that have been running for over 50 years. We cut and sew in our Brooklyn atelier. We back every piece with a lifetime repair guarantee. This is not vintage — this is vintage quality, built to last.' }}</p>
<p class="vintage-detail">{{ section.settings.v_detail | default: '"American craftsmanship is not dead. We''re just harder to find."' }}</p>
</div>
</section>
<section class="products" id="collection">
<div class="products-header">
<div>
<p class="products-label">{{ section.settings.col_label | default: 'The Collection' }}</p>
<h2 class="products-title">{{ section.settings.col_title | default: 'Retrograde SS 2026' }}</h2>
</div>
<p class="products-count">{{ section.settings.col_count | default: '06 PIECES' }}</p>
</div>
<div class="products-grid">
{% for block in section.blocks %}
<div class="product-card" {{ block.shopify_attributes }}>
<div class="product-img">
<span class="product-num">{{ forloop.index | string | pad_left: 2, '0' }}</span>
{% if block.settings.badge %}<span class="product-badge">{{ block.settings.badge }}</span>{% endif %}
</div>
<div class="product-info">
<h3 class="product-name">{{ block.settings.name | default: 'Product' }}</h3>
<p class="product-detail">{{ block.settings.detail | default: 'Premium Fabric' }}</p>
<p class="product-price">{{ block.settings.price | default: '$185' }}</p>
</div>
</div>
{% endfor %}
</div>
</section>
<section class="quote-section">
<p class="quote-label">{{ section.settings.q_label | default: 'Manifesto' }}</p>
<p class="quote-text">{{ section.settings.quote | default: 'Built to last.<br>Designed to <span class="rust">matter</span>.' }}</p>
</section>
<footer class="footer" id="footer">
<div class="footer-inner">
<div class="footer-brand">{{ section.settings.brand | default: 'JZZW' }}</div>
<div class="footer-links">
<a href="#">All Products</a>
<a href="#">About</a>
<a href="#">Stockists</a>
<a href="#">Instagram</a>
</div>
<p class="footer-copy">© {{ 'now' | date: '%Y' }} — {{ section.settings.footer_loc | default: 'Brooklyn, NY' }}</p>
</div>
</footer>
</div>
{% schema %}
{
  "name": "JZZW V14 Retrograde",
  "tag": "section",
  "class": "jzzw-section",
  "settings": [
    {"type": "text", "id": "brand", "label": "Brand", "default": "JZZW"},
    {"type": "text", "id": "tag", "label": "Hero Tag", "default": "Retrograde — SS 2026"},
    {"type": "textarea", "id": "title", "label": "Hero Title", "default": "AMERI<br><em>cana</em>"},
    {"type": "textarea", "id": "sub", "label": "Hero Subtitle", "default": "Heritage reborn. The grit of the workyard, the pride of the maker."},
    {"type": "text", "id": "cta", "label": "Primary CTA", "default": "Shop Collection"},
    {"type": "text", "id": "cta2", "label": "Secondary CTA", "default": "Our Story"},
    {"type": "text", "id": "cta_nav", "label": "Nav CTA", "default": "Shop Now"},
    {"type": "text", "id": "emblem", "label": "Emblem Text", "default": "JZ"},
    {"type": "text", "id": "est", "label": "Est Text", "default": "EST. 2024"},
    {"type": "text", "id": "emblem_sub", "label": "Emblem Sub", "default": "New York"},
    {"type": "text", "id": "s1", "label": "Strip 1", "default": "American Made"},
    {"type": "text", "id": "s2", "label": "Strip 2", "default": "Retrograde"},
    {"type": "text", "id": "s3", "label": "Strip 3", "default": "SS 2026"},
    {"type": "text", "id": "s4", "label": "Strip 4", "default": "Heritage Reborn"},
    {"type": "text", "id": "n1", "label": "Nav 1", "default": "Collection"},
    {"type": "text", "id": "n2", "label": "Nav 2", "default": "Story"},
    {"type": "text", "id": "n3", "label": "Nav 3", "default": "Contact"},
    {"type": "text", "id": "img_label", "label": "Image Label", "default": "Archive No. 001"},
    {"type": "text", "id": "v_label", "label": "Vintage Section Label", "default": "Heritage"},
    {"type": "textarea", "id": "v_title", "label": "Vintage Section Title", "default": "Made in<br><em>America</em>"},
