{%- comment -%} JZZW V4 Cinematic Parallax - Shopify Section {%- endcomment -%}
<style>
.jzzw-v4-cine *{margin:0;padding:0;box-sizing:border-box}
.jzzw-v4-cine{font-family:'Outfit',sans-serif;background:#0a0a0a;color:#f5f0e8;min-height:100vh;overflow-x:hidden}
.jzzw-v4-cine ::selection{background:#e94560;color:#fff}
.jzzw-v4-cine .hero{height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.jzzw-v4-cine .hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0a0a0a 0%,#1a0a10 40%,#0a1520 70%,#0a0a0a 100%);z-index:0}
.jzzw-v4-cine .hero-lines{position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 80px,rgba(233,69,96,.03) 80px,rgba(233,69,96,.03) 81px),repeating-linear-gradient(90deg,transparent,transparent 80px,rgba(233,69,96,.03) 80px,rgba(233,69,96,.03) 81px);z-index:1}
.jzzw-v4-cine .hero-vignette{position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 30%,rgba(0,0,0,.7) 100%);z-index:2;pointer-events:none}
.jzzw-v4-cine .hero-content{position:relative;z-index:3;text-align:center;max-width:800px;padding:2rem}
.jzzw-v4-cine .hero-tag{font-size:.7rem;letter-spacing:.5em;text-transform:uppercase;color:#e94560;margin-bottom:2rem;opacity:0;animation:slideUp 1s ease forwards .3s}
.jzzw-v4-cine .hero-title{font-size:clamp(3rem,10vw,8rem);font-weight:700;letter-spacing:-.02em;line-height:.95;margin-bottom:1.5rem;opacity:0;animation:slideUp 1s ease forwards .5s}
.jzzw-v4-cine .hero-title .accent{color:#e94560}
.jzzw-v4-cine .hero-sub{font-size:1rem;font-weight:300;line-height:1.8;color:rgba(245,240,232,.5);max-width:500px;margin:0 auto 2.5rem;opacity:0;animation:slideUp 1s ease forwards .7s}
.jzzw-v4-cine .hero-cta{opacity:0;animation:slideUp 1s ease forwards .9s}
.jzzw-v4-cine .btn-cine{padding:1rem 3rem;background:#e94560;color:#fff;text-decoration:none;font-size:.8rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;transition:all .3s;display:inline-block}
.jzzw-v4-cine .btn-cine:hover{background:#ff6b8a;transform:translateY(-2px);box-shadow:0 10px 30px rgba(233,69,96,.3)}
.jzzw-v4-cine .hero-countdown{margin-top:2rem;opacity:0;animation:slideUp 1s ease forwards 1.1s}
.jzzw-v4-cine .countdown-label{font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;color:rgba(245,240,232,.3);margin-bottom:.5rem}
.jzzw-v4-cine .countdown-num{font-size:1.5rem;font-weight:700;color:#e94560}
@keyframes slideUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
.jzzw-v4-cine .scroll-hint{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:.5rem;opacity:0;animation:slideUp 1s ease forwards 1.5s}
.jzzw-v4-cine .scroll-hint span{font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(245,240,232,.2)}
.jzzw-v4-cine .scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,#e94560,transparent);animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.jzzw-v4-cine .strip{background:#e94560;padding:1rem 0;overflow:hidden}
.jzzw-v4-cine .strip-inner{display:inline-flex;animation:marquee 20s linear infinite;white-space:nowrap}
.jzzw-v4-cine .strip-item{font-size:.75rem;letter-spacing:.3em;font-weight:700;color:#fff;padding:0 2rem}
.jzzw-v4-cine .strip-item::after{content:'//';margin-left:2rem;opacity:.5}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.jzzw-v4-cine .products{padding:8rem 4rem}
.jzzw-v4-cine .products-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:5rem}
.jzzw-v4-cine .products-label{font-size:.65rem;letter-spacing:.4em;text-transform:uppercase;color:#e94560;margin-bottom:.5rem}
.jzzw-v4-cine .products-title{font-size:clamp(2rem,5vw,4rem);font-weight:700}
.jzzw-v4-cine .products-count{font-size:.75rem;color:rgba(245,240,232,.3)}
.jzzw-v4-cine .products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.jzzw-v4-cine .product-card{background:rgba(255,255,255,.03);border:1px solid rgba(233,69,96,.1);transition:all .4s;position:relative;overflow:hidden}
.jzzw-v4-cine .product-card::after{content:'';position:absolute;inset:0;border:1px solid rgba(233,69,96,.3);transform:scale(.95);opacity:0;transition:all .4s}
.jzzw-v4-cine .product-card:hover{background:rgba(233,69,96,.05);transform:translateY(-4px)}
.jzzw-v4-cine .product-card:hover::after{opacity:1;transform:scale(1)}
.jzzw-v4-cine .product-img{aspect-ratio:4/5;background:linear-gradient(135deg,#111 0%,#1a1a2e 100%);position:relative}
.jzzw-v4-cine .product-img::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(233,69,96,.02) 3px,rgba(233,69,96,.02) 4px)}
.jzzw-v4-cine .product-num{position:absolute;top:1rem;left:1rem;font-size:.6rem;color:rgba(245,240,232,.2);letter-spacing:.1em}
.jzzw-v4-cine .product-badge{position:absolute;top:1rem;right:1rem;background:#e94560;color:#fff;font-size:.55rem;font-weight:700;letter-spacing:.1em;padding:.3rem .6rem}
.jzzw-v4-cine .product-info{padding:1.5rem}
.jzzw-v4-cine .product-name{font-size:1rem;font-weight:500;margin-bottom:.3rem}
.jzzw-v4-cine .product-detail{font-size:.75rem;color:rgba(245,240,232,.35);margin-bottom:.5rem}
.jzzw-v4-cine .product-price{font-size:1.2rem;font-weight:700;color:#e94560}
.jzzw-v4-cine .manifesto{padding:8rem 4rem;background:linear-gradient(180deg,rgba(233,69,96,.05) 0%,transparent 100%);text-align:center;border-top:1px solid rgba(233,69,96,.1)}
.jzzw-v4-cine .manifesto-label{font-size:.6rem;letter-spacing:.5em;text-transform:uppercase;color:#e94560;margin-bottom:2rem}
.jzzw-v4-cine .manifesto-text{font-size:clamp(1.5rem,4vw,3rem);font-weight:300;line-height:1.5;max-width:700px;margin:0 auto}
.jzzw-v4-cine .manifesto-text .accent{color:#e94560;font-weight:700}
.jzzw-v4-cine .footer{background:#060608;padding:4rem;border-top:1px solid rgba(233,69,96,.1)}
.jzzw-v4-cine .footer-inner{max-width:1400px;margin:0 auto;display:flex;justify-content:space-between;align-items:center}
.jzzw-v4-cine .footer-brand{font-size:1.5rem;font-weight:700;letter-spacing:.2em;color:#e94560}
.jzzw-v4-cine .footer-text{font-size:.75rem;color:rgba(245,240,232,.25)}
@media(max-width:900px){.jzzw-v4-cine .products-grid{grid-template-columns:repeat(2,1fr)}.jzzw-v4-cine .hero-content{padding:1rem}}
@media(max-width:600px){.jzzw-v4-cine .products-grid{grid-template-columns:1fr}}
</style>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<div class="jzzw-v4-cine">
<div class="hero">
<div class="hero-bg"></div><div class="hero-lines"></div><div class="hero-vignette"></div>
<div class="hero-content">
<p class="hero-tag">{{ section.settings.hero_tag | default: 'SS 2026 — LIMITED DROP' }}</p>
<h1 class="hero-title">{{ section.settings.hero_title | default: 'STREET<br><span class="accent">REDEFINED</span>' }}</h1>
<p class="hero-sub">{{ section.settings.hero_sub | default: 'Born from the intersection of New York grit and Tokyo precision. Every piece engineered for those who refuse to blend in.' }}</p>
<div class="hero-cta"><a href="#collection" class="btn-cine">{{ section.settings.cta | default: 'Shop the Drop' }}</a></div>
<div class="hero-countdown"><p class="countdown-label">{{ section.settings.countdown_label | default: 'Drop Live In' }}</p><p class="countdown-num">{{ section.settings.countdown | default: '00:04:23:18' }}</p></div>
</div>
<div class="scroll-hint"><span>Scroll</span><div class="scroll-line"></div></div>
</div>
<div class="strip">
<div class="strip-inner">
<span class="strip-item">SS 2026 COLLECTION</span><span class="strip-item">LIMITED QUANTITIES</span><span class="strip-item">HANDCRAFTED</span><span class="strip-item">WORLDWIDE SHIPPING</span>
<span class="strip-item">SS 2026 COLLECTION</span><span class="strip-item">LIMITED QUANTITIES</span><span class="strip-item">HANDCRAFTED</span><span class="strip-item">WORLDWIDE SHIPPING</span>
</div>
</div>
<section class="products" id="collection">
<div class="products-header">
<div><p class="products-label">{{ section.settings.collection_label | default: 'THE DROP' }}</p><h2 class="products-title">{{ section.settings.collection_title | default: 'SS 2026' }}</h2></div>
<p class="products-count">{{ section.settings.collection_count | default: '06 PIECES' }}</p>
</div>
<div class="products-grid">
{% for block in section.blocks %}
<div class="product-card" {{ block.shopify_attributes }}>
<div class="product-img">{% if block.settings.badge %}<span class="product-badge">{{ block.settings.badge }}</span>{% endif %}<span class="product-num">{{ forloop.index | string | pad_left: 2, '0' }}</span></div>
<div class="product-info"><h3 class="product-name">{{ block.settings.product_name }}</h3><p class="product-detail">{{ block.settings.product_detail }}</p><p class="product-price">{{ block.settings.product_price }}</p></div>
</div>
{% endfor %}
</div>
</section>
<section class="manifesto">
<p class="manifesto-label">{{ section.settings.manifesto_label | default: 'THE MOVEMENT' }}</p>
<p class="manifesto-text">{{ section.settings.manifesto | default: 'We do not design for <span class="accent">trends</span>. We design for <span class="accent">legacies</span>.' }}</p>
</section>
<footer class="footer">
<div class="footer-inner"><div class="footer-brand">{{ section.settings.brand | default: 'JZZW' }}</div><p class="footer-text">© {{ 'now' | date: '%Y' }} — New York → Tokyo</p></div>
</footer>
</div>
